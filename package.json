{
  "name": "zync-debate-moderator",
  "version": "1.0.0",
  "description": "AI-Powered Online Debate Moderator Platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "ai-server": "cd ai-server && python -m uvicorn main:app --reload --port 8000",
    "install-all": "npm install && cd client && npm install && cd ../ai-server && pip install -r requirements.txt",
    "test": "node --test server/tests/*.test.js"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bad-words": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "leo-profanity": "^1.9.0",
    "mongoose": "^8.0.3",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "author": "Zync Team",
  "license": "MIT"
}
